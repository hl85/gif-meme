# Local app runtime configuration for Next.js build/runtime.
# Copy to .env.local and keep the real file out of git.

LOCAL_PORT=8787
NEXT_PUBLIC_APP_URL=http://localhost:8787
NEXT_PUBLIC_BASE_URL=http://localhost:8787
PLAYWRIGHT_BASE_URL=http://localhost:8787

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
JWT_SECRET=replace-with-a-long-random-string
KLIPY_API_KEY=your-klipy-api-key
ADMIN_EMAILS=admin@example.com,another-admin@example.com

# Optional. Analytics widget in /admin will degrade gracefully if these stay empty locally.
CF_ACCOUNT_ID=
CF_ANALYTICS_TOKEN=
